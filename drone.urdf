<?xml version="1.0" ?>
<robot name="drone">

  <link name="base">

    <!-- Visual (your actual mesh) -->
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <!-- Scale down (adjust if needed) -->
        <mesh filename="drone.obj" scale="0.5 0.5 0.5"/>
      </geometry>
    </visual>

    <!-- Collision (simple shape for stability) -->
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- Approximate drone body -->
        <box size="0.3 0.3 0.1"/>
      </geometry>
    </collision>

    <!-- Physics -->
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="1.5"/>
      <inertia 
        ixx="0.01" ixy="0.0" ixz="0.0"
        iyy="0.01" iyz="0.0"
        izz="0.02"/>
    </inertial>

  </link>

</robot>